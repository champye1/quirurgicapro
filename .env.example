# ─────────────────────────────────────────────────────────────────────────────
# QuirúrgicaPro — Variables de entorno
# Copia este archivo como .env.development o .env.production y completa los valores.
# NUNCA subas archivos .env con valores reales a git.
# ─────────────────────────────────────────────────────────────────────────────

# ── Supabase ──────────────────────────────────────────────────────────────────
# URL del proyecto Supabase. Se encuentra en: Project Settings → API → Project URL
VITE_SUPABASE_URL=https://<tu-proyecto>.supabase.co

# Clave anónima (pública) del proyecto Supabase.
# Se encuentra en: Project Settings → API → anon public
VITE_SUPABASE_ANON_KEY=<tu-anon-key>

# ── Entorno ───────────────────────────────────────────────────────────────────
# Valores válidos: development | production | test
VITE_APP_ENV=development

# ── Sentry (monitoreo de errores) ─────────────────────────────────────────────
# DSN del proyecto Sentry. Se encuentra en: Sentry → Settings → Projects → <proyecto> → Client Keys
# Dejar vacío en desarrollo para desactivar Sentry.
VITE_SENTRY_DSN=https://<clave>@<org>.ingest.sentry.io/<proyecto-id>
